# Custom Dockerfile for django-pwa-assets tests
FROM divio/multi-python:latest

USER root

# Install system libraries required by cairosvg and other dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    libcairo2 \
    libpango-1.0-0 \
    libpangocairo-1.0-0 \
    libgdk-pixbuf2.0-0 \
    libffi-dev \
    shared-mime-info \
    && rm -rf /var/lib/apt/lists/*

USER tox
